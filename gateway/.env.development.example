# 개발용 API Gateway 환경변수 템플릿
# .env.development.example → .env 복사 후 값 채우기

GATEWAY_PORT=8000

# auth-service, BFF 주소
# Docker Compose 'services' 프로파일 사용 시: http://auth-service:8081
# 호스트에서 직접 실행 시: http://localhost:8081
GATEWAY_AUTH_URI=http://localhost:8081

# BFF 주소
# Docker Compose 'bff' 프로파일 사용 시: http://bff:8080
# 호스트에서 직접 실행 시: http://localhost:8080
GATEWAY_BFF_URI=http://localhost:8080

# auth-service와 반드시 동일한 값이어야 함
AUTH_JWT_HMAC_SECRET=change-me-in-production-change-me-in-production

# docker compose가 자동 로드하는 루트 .env 템플릿
# 사용법: cp deploy/local/.env.example .env  (services/ 루트에 복사)

# ── DB ──────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ── JWT (auth-service ↔ gateway 반드시 동일한 값) ───────────────────
AUTH_JWT_HMAC_SECRET=change-me-in-production-change-me-in-production

# ── Google OAuth (auth-service 로컬 실행 시에도 필요) ─────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/auth/google/callback

# ── Docker 이미지 (기본값 유지해도 무방) ─────────────────────────────
BFF_IMAGE=yyubin/candle-bff:dev
GATEWAY_IMAGE=yyubin/candle-gateway:dev

# ── Gateway 라우팅 ────────────────────────────────────────────────────
# auth-service를 'services' 프로파일 Docker로 띄울 때: http://auth-service:8081
# 호스트에서 직접 실행 시: 아래 기본값(host.docker.internal) 사용
# GATEWAY_AUTH_URI=http://host.docker.internal:8081
# BFF를 'bff' 프로파일 Docker로 띄울 때: http://bff:8080
# GATEWAY_BFF_URI=http://bff:8080

# Auth Service - local development
SPRING_PROFILES_ACTIVE=local
AUTH_SERVER_PORT=8081
AUTH_DB_URL=jdbc:postgresql://localhost:5432/candle?currentSchema=auth,public
AUTH_DB_USERNAME=candle
AUTH_DB_PASSWORD=candle
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
AUTH_OUTBOX_PUBLISH_INTERVAL_MS=5000
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/auth/google/callback
# 클라이언트(웹/앱)가 보내는 redirect_uri 허용목록(콤마 구분). 토큰 교환은 이 값이 인가 때와 일치해야 한다.
GOOGLE_OAUTH_ALLOWED_REDIRECT_URIS=http://localhost:3000/auth/callback,https://your-web.vercel.app/auth/callback
KAKAO_OAUTH_CLIENT_ID=your-kakao-rest-api-key
KAKAO_OAUTH_CLIENT_SECRET=your-kakao-client-secret
KAKAO_OAUTH_REDIRECT_URI=http://localhost:3000/auth/kakao/callback
KAKAO_OAUTH_ALLOWED_REDIRECT_URIS=http://localhost:3000/auth/callback,https://your-web.vercel.app/auth/callback
NAVER_OAUTH_CLIENT_ID=your-naver-client-id
NAVER_OAUTH_CLIENT_SECRET=your-naver-client-secret
NAVER_OAUTH_REDIRECT_URI=http://localhost:3000/auth/naver/callback
NAVER_OAUTH_ALLOWED_REDIRECT_URIS=http://localhost:3000/auth/callback,https://your-web.vercel.app/auth/callback
AUTH_JWT_ISSUER=candle-auth-local
AUTH_JWT_HMAC_SECRET=local-only-change-this-secret-to-at-least-32-bytes
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=Lax

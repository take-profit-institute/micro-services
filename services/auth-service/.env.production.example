# Auth Service - production
SPRING_PROFILES_ACTIVE=prod
AUTH_SERVER_PORT=8081
AUTH_DB_URL=jdbc:postgresql://postgres:5432/candle_auth
AUTH_DB_USERNAME=replace-with-production-db-user
AUTH_DB_PASSWORD=replace-with-secret-manager-reference
KAFKA_BOOTSTRAP_SERVERS=replace-with-msk-bootstrap-servers
AUTH_OUTBOX_PUBLISH_INTERVAL_MS=5000
GOOGLE_OAUTH_CLIENT_ID=replace-with-production-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=replace-with-secret-manager-reference
GOOGLE_OAUTH_REDIRECT_URI=https://api.example.com/auth/google/callback
# 클라이언트(웹/앱)가 보내는 redirect_uri 허용목록(콤마 구분). Google Console에도 동일하게 등록해야 한다.
GOOGLE_OAUTH_ALLOWED_REDIRECT_URIS=https://web.example.com/auth/callback
KAKAO_OAUTH_CLIENT_ID=replace-with-production-kakao-rest-api-key
KAKAO_OAUTH_CLIENT_SECRET=replace-with-secret-manager-reference
KAKAO_OAUTH_REDIRECT_URI=https://api.example.com/auth/kakao/callback
KAKAO_OAUTH_ALLOWED_REDIRECT_URIS=https://web.example.com/auth/callback
NAVER_OAUTH_CLIENT_ID=replace-with-production-naver-client-id
NAVER_OAUTH_CLIENT_SECRET=replace-with-secret-manager-reference
NAVER_OAUTH_REDIRECT_URI=https://api.example.com/auth/naver/callback
NAVER_OAUTH_ALLOWED_REDIRECT_URIS=https://web.example.com/auth/callback
AUTH_JWT_ISSUER=candle-auth
AUTH_JWT_HMAC_SECRET=replace-with-secret-manager-reference
AUTH_COOKIE_DOMAIN=.example.com
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAME_SITE=Lax
